{
  "name": "vellum-engine",
  "version": "2.0.0-alpha.0",
  "description": "VELLUM II (Palimpsest) — a living-narrative engine for Lumiverse: event-log chronicle, hybrid recall, dramatic-irony knowledge model, and an illuminated UI.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "build:backend": "tsup --entry.backend src/backend.ts",
    "build:frontend": "tsup --entry.frontend src/ui/app.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "lumiverse-spindle-types": "^0.5.28",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "zod": "^3.23.0"
  }
}
