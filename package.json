{
  "name": "vellum-engine",
  "version": "2.1.0-beta.2",
  "description": "VELLUM II (Palimpsest) — a living-narrative engine for Lumiverse: event-log chronicle, hybrid recall, dramatic-irony knowledge model, and an illuminated UI.",
  "license": "AGPL-3.0-only",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "build:backend": "tsup --entry.backend src/backend.ts",
    "build:frontend": "tsup --entry.frontend src/ui/app.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@fontsource/cinzel": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/orbitron": "^5.2.8",
    "@fontsource/quicksand": "^5.2.10",
    "@types/node": "^22.0.0",
    "lumiverse-spindle-types": "^0.6.3",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "zod": "^3.23.0"
  }
}
