  {
    "script_id": "vellum2-reverie-card",
    "name": "VELLUM II ✧ Reverie (display)",
    "folder": "VELLUM II",
    "description": "Renders the <reverie> planning block as a collapsed dim marginal card in the chat, and strips it entirely from the context sent on later turns. Display-only; disable to hide reasoning completely.",
    "find_regex": "<reverie>([\\s\\S]*?)<\\/\\s*rever[a-z]*\\s*>",
    "replace_string": "<style>.v2r{max-width:780px;margin:12px auto;font-family:'JetBrains Mono',ui-monospace,monospace}.v2r-card{border:1px solid rgba(205,168,78,.28);border-left:3px solid #cda84e;border-radius:10px;overflow:hidden;background:linear-gradient(165deg,rgba(24,21,16,.96),rgba(30,26,20,.95))}.v2r-card>summary{cursor:pointer;list-style:none;padding:9px 15px;font-family:'Cormorant Garamond',Georgia,serif;font-size:12.5px;letter-spacing:2px;text-transform:uppercase;color:#cdbfa0}.v2r-card>summary::-webkit-details-marker{display:none}.v2r-card>summary::before{content:'❖ ';color:#cda84e}.v2r-in{padding:6px 17px 15px;font-size:11.5px;line-height:1.6;color:#bcb29c;white-space:pre-wrap;border-top:1px solid rgba(205,168,78,.16)}</style><details class='v2r v2r-card'><summary>Reverie — the writer’s notebook</summary><div class='v2r-in'>$1</div></details>",
    "flags": "gi",
    "placement": [
      "ai_output"
    ],
    "target": [
      "display"
    ],
    "scope": "global",
    "scope_id": null,
    "min_depth": null,
    "max_depth": null,
    "trim_strings": [],
    "run_on_edit": true,
    "substitute_macros": "none",
    "disabled": false,
