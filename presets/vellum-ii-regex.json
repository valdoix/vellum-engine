    "script_id": "vellum2-slop-mark",
    "name": "VELLUM II ✧ Slop Proofreader (display)",
    "description": "Optional, disabled by default. Flags a few stubborn cliches in the DISPLAYED message with a faint marginal mark so you can see them — never touches the prompt or the stored message the engine reads. Pair with the Anti-Slop \"Slop Proofreader\" toggle.",
    "find_regex": "\\b(ozone|shiver(?:ed|s)? down (?:his|her|their|my) spine|breath (?:he|she|they|I) (?:didn't|did not) know (?:he|she|they|I) (?:was|were) holding|knuckles white|sent shivers|barely above a whisper)\\b",
    "replace_string": "$1<span style=\"color:#9a7d4e;font-size:.8em;opacity:.7\" title=\"VELLUM proofreader: stock phrasing\"> ✎</span>",
    "target": [
