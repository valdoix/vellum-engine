    "script_id": "vellum2-state-strip",
    "name": "VELLUM II ✧ State Block (hide)",
    "folder": "VELLUM II",
    "description": "Removes the <vellum>...</vellum> JSON state block from the visible chat AND from the context sent to the model on later turns. The tracker reads it from the raw stored message regardless, so stripping it here keeps the prose clean and the context lean.",
    "find_regex": "\\s*(?:‹vellum›|<vellum>)[\\s\\S]*?(?:‹\\/vellum›|<\\/vellum>)\\s*",
    "replace_string": "",
    "flags": "gi",
    "placement": [
      "ai_output"
    ],
    "target": [
      "display",
      "prompt"
    ],
    "scope": "global",
    "scope_id": null,
    "min_depth": null,
    "max_depth": null,
    "trim_strings": [],
    "run_on_edit": true,
    "substitute_macros": "none",
    "disabled": false,
    "sort_order": 0,
    "metadata": {}
