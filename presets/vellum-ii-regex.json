  {
    "script_id": "vellum2-state-context-strip",
    "name": "VELLUM II ✧ State Block (context strip)",
    "folder": "VELLUM II",
    "description": "Strips the <vellum> block from the context sent to the model on LATER turns, keeping the prompt lean. min_depth 1 deliberately KEEPS the most recent turn's block in context: it is the model's own correctly-formatted example and re-showing it every turn is the single strongest cure for the block being dropped or malformed over a long chat. Accepts every fence spelling. OPTIONS: to keep ALL turns' blocks in context (maximum format reinforcement, higher token cost) set disabled:true on THIS script; to strip EVERY turn including the latest (legacy lean behavior, no reinforcement) set min_depth:null.",
    "find_regex": "\\s*(?:‹vellum›|<vellum>|```vellum|\\[VELLUM\\])[\\s\\S]*?(?:‹\\/vellum›|<\\/vellum>|\\[\\/VELLUM\\]|```)\\s*",
    "replace_string": "",
    "flags": "gi",
    "placement": [
      "ai_output"
    ],
    "target": [
      "prompt"
    ],
    "scope": "global",
    "scope_id": null,
    "min_depth": 1,
    "max_depth": null,
    "trim_strings": [],
    "run_on_edit": true,
    "substitute_macros": "none",
    "disabled": false,
    "sort_order": 0,
    "metadata": {}
  },
  {
    "script_id": "vellum2-reverie-card",
    "name": "VELLUM II ✧ Reverie (display)",
    "folder": "VELLUM II",
    "description": "Renders the <reverie> planning block as a collapsed dim marginal card in the chat, and strips it from the context sent on later turns. The opening <reverie> tag is optional so a host that doesn't echo the assistant prefill (leaving the reply starting mid-plan) still gets its planning collapsed instead of leaked. Display-only; disable to hide reasoning completely.",
    "find_regex": "(?:<reverie>)?([\\s\\S]*?)<\\/\\s*rever[a-z]*\\s*>",
    "replace_string": "<style>.v2r{max-width:780px;margin:12px auto;font-family:var(--vmono,'JetBrains Mono',ui-monospace,monospace)}.v2r-card{border:var(--vborder,1px) solid rgba(var(--vg-rgb,205,168,78),.28);border-left:3px solid var(--vg,#cda84e);border-radius:var(--vradius,10px);overflow:hidden;background:linear-gradient(165deg,var(--vsurf-1,rgba(24,21,16,.96)),var(--vsurf-2,rgba(30,26,20,.95)))}.v2r-card>summary{cursor:pointer;list-style:none;padding:9px 15px;font-family:var(--vserif,'Cormorant Garamond',Georgia,serif);font-size:12.5px;letter-spacing:2px;text-transform:uppercase;color:var(--vi,#cdbfa0)}.v2r-card>summary::-webkit-details-marker{display:none}.v2r-card>summary::before{content:'❖ ';color:var(--vg,#cda84e)}.v2r-in{padding:6px 17px 15px;font-size:11.5px;line-height:1.6;color:var(--vi2,#bcb29c);white-space:pre-wrap;border-top:var(--vborder,1px) solid rgba(var(--vg-rgb,205,168,78),.16)}</style><details class='v2r v2r-card'><summary>Reverie — the writer’s notebook</summary><div class='v2r-in'>$1</div></details>",
    "flags": "gi",
    "placement": [
      "ai_output"
    ],
    "target": [
