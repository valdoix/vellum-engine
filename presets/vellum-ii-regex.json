[
  {
    "script_id": "vellum2-state-card",
    "name": "VELLUM II ✧ State Block (display)",
    "folder": "VELLUM II",
    "description": "Renders the <vellum> JSON state block as a collapsed dim marginal card in the chat (mirroring the Reverie card) instead of deleting it. The tracker still reads the block from the raw stored message. Accepts every fence spelling the parser tolerates (<vellum>, ‹vellum›, ```vellum, [VELLUM]) so a block never leaks as raw text if the model drifts. Display-only; disable to hide the block completely.",
    "find_regex": "(?:‹vellum›|<vellum>|```vellum|\\[VELLUM\\])([\\s\\S]*?)(?:‹\\/vellum›|<\\/vellum>|\\[\\/VELLUM\\]|```)",
    "replace_string": "<style>.v2s{max-width:780px;margin:12px auto;font-family:var(--vmono,'JetBrains Mono',ui-monospace,monospace)}.v2s-card{border:var(--vborder,1px) solid rgba(var(--vg-rgb,200,146,62),.28);border-left:3px solid var(--vg,#c8923e);border-radius:var(--vradius,10px);overflow:hidden;background:linear-gradient(165deg,var(--vsurf-1,rgba(26,22,16,.97)),var(--vsurf-2,rgba(15,13,10,.985)))}.v2s-card>summary{cursor:pointer;list-style:none;padding:9px 15px;font-family:var(--vserif,'Cormorant Garamond',Georgia,serif);font-size:12.5px;letter-spacing:2px;text-transform:uppercase;color:var(--vi,#e7d6ad)}.v2s-card>summary::-webkit-details-marker{display:none}.v2s-card>summary::before{content:'▤ ';color:var(--vg,#c8923e)}.v2s-in{padding:6px 17px 15px;font-size:11px;line-height:1.55;color:var(--vi2,#cdbfa0);white-space:pre-wrap;word-break:break-word;border-top:var(--vborder,1px) solid rgba(var(--vg-rgb,200,146,62),.16)}</style><details class='v2s v2s-card'><summary>State — the engine’s ledger</summary><div class='v2s-in'>$1</div></details>",
    "flags": "gi",
    "placement": [
      "ai_output"
    ],
    "target": [
      "display"
    ],
    "scope": "global",
    "scope_id": null,
    "min_depth": null,
    "max_depth": null,
    "trim_strings": [],
    "run_on_edit": true,
