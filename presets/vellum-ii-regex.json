  {
    "script_id": "vellum2-reverie-context-strip",
    "name": "VELLUM II ✧ Reverie (context strip)",
    "folder": "VELLUM II",
    "description": "Strips <reverie> from the context sent to the model on LATER turns so planning never re-enters the prompt (display card above stays visible). min_depth 1 KEEPS the latest turn's reverie in context — its trailing STATE: line is the model's own worked example of the block it must emit, and re-showing it is a strong cure for format drift. Open tag optional so a non-echoed prefill is still stripped. OPTIONS: keep ALL reveries in context → set disabled:true; strip EVERY turn incl. latest → set min_depth:null.",
    "find_regex": "\\s*(?:<reverie>)?[\\s\\S]*?<\\/\\s*rever[a-z]*\\s*>\\s*",
    "replace_string": "",
    "flags": "gi",
    "placement": [
